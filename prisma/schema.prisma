generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmissionStatus {
  eligible
  disqualified
  removed
}

enum AccessEventAction {
  view_coach
  rescore
  copy_prompt
}

model Contact {
  id                         String             @id @default(cuid())
  email                      String             @unique
  firstName                  String             @map("first_name")
  lastName                   String             @map("last_name")
  emailConfirmedAt           DateTime?          @map("email_confirmed_at")
  emailConfirmationTokenHash String?            @unique @map("email_confirmation_token_hash")
  emailConfirmationSentAt    DateTime?          @map("email_confirmation_sent_at")
  createdAt                  DateTime           @default(now()) @map("created_at")
  updatedAt                  DateTime           @updatedAt @map("updated_at")
  unsubscribedAt             DateTime?          @map("unsubscribed_at")
  accessTokens               AccessToken[]
  coachSessions              CoachSession[]
  contestWinners             ContestWinner[]
  promptSubmissions          PromptSubmission[]

  @@map("contacts")
}

model PromptSubmission {
  id                  String             @id @default(cuid())
  contactId           String             @map("contact_id")
  promptText          String             @map("prompt_text")
  promptHash          String             @map("prompt_hash")
  overallScore        Int                @map("overall_score")
  whoScore            Int                @map("who_score")
  taskScore           Int                @map("task_score")
  contextScore        Int                @map("context_score")
  outputScore         Int                @map("output_score")
  feedbackSummary     String             @map("feedback_summary")
  status              SubmissionStatus   @default(eligible)
  disqualifiedReason  String?            @map("disqualified_reason")
  reviewedAt          DateTime?          @map("reviewed_at")
  reviewedBy          String?            @map("reviewed_by")
  createdAt           DateTime           @default(now()) @map("created_at")
  ipHash              String?            @map("ip_hash")
  userAgent           String?            @map("user_agent")
  contact             Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contestWinners      ContestWinner[]

  @@unique([contactId])
  @@index([createdAt])
  @@index([status])
  @@map("prompt_submissions")
}

model AccessToken {
  id                 String             @id @default(cuid())
  contactId          String             @map("contact_id")
  tokenHash          String             @unique @map("token_hash")
  tokenCiphertext    String?            @map("token_ciphertext")
  tokenPrefix        String?            @map("token_prefix")
  createdAt          DateTime           @default(now()) @map("created_at")
  lastUsedAt         DateTime?          @map("last_used_at")
  revokedAt          DateTime?          @map("revoked_at")
  firstIpHash        String?            @map("first_ip_hash")
  lastIpHash         String?            @map("last_ip_hash")
  ipMismatchCount    Int                @default(0) @map("ip_mismatch_count")
  contact            Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  coachSessions      CoachSession[]
  tokenAccessEvents  TokenAccessEvent[]

  @@index([contactId])
  @@map("access_tokens")
}

model TokenAccessEvent {
  id            String            @id @default(cuid())
  accessTokenId String            @map("access_token_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  ipHash        String?           @map("ip_hash")
  userAgent     String?           @map("user_agent")
  action        AccessEventAction
  accessToken   AccessToken       @relation(fields: [accessTokenId], references: [id], onDelete: Cascade)

  @@index([accessTokenId, createdAt])
  @@map("token_access_events")
}

model CoachSession {
  id            String      @id @default(cuid())
  contactId     String      @map("contact_id")
  accessTokenId String      @map("access_token_id")
  currentPrompt String      @map("current_prompt")
  draftVersion  Int         @default(1) @map("draft_version")
  overallScore  Int         @map("overall_score")
  whoScore      Int         @map("who_score")
  taskScore     Int         @map("task_score")
  contextScore  Int         @map("context_score")
  outputScore   Int         @map("output_score")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  accessToken   AccessToken @relation(fields: [accessTokenId], references: [id], onDelete: Cascade)
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([accessTokenId])
  @@map("coach_sessions")
}

model ContestWinner {
  id                 String           @id @default(cuid())
  contactId          String           @map("contact_id")
  promptSubmissionId String           @map("prompt_submission_id")
  selectedAt         DateTime         @default(now()) @map("selected_at")
  selectedBy         String           @map("selected_by")
  prizeLabel         String           @default("weekly prize") @map("prize_label")
  notes              String?
  contact            Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  promptSubmission   PromptSubmission @relation(fields: [promptSubmissionId], references: [id], onDelete: Cascade)

  @@unique([contactId])
  @@index([selectedAt])
  @@map("contest_winners")
}

model AdminLoginCode {
  id        String    @id @default(cuid())
  email     String
  codeHash  String    @map("code_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@map("admin_login_codes")
}
